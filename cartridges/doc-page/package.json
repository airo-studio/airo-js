{
  "name": "@airo-js-cartridges/doc-page",
  "version": "0.0.0",
  "private": true,
  "description": "DocPage cartridge — schema-driven documentation pages with full AIO surface coverage (Schema.org TechArticle, llms.txt, MCP tools). First-party reference cartridge for the airo-js framework.",
  "keywords": [
    "airo-cartridge",
    "documentation",
    "schema-org",
    "llms-txt",
    "aio"
  ],
  "author": "AI/RO contributors",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/airo-studio/airo-js.git",
    "directory": "cartridges/doc-page"
  },
  "homepage": "https://github.com/airo-studio/airo-js/tree/main/cartridges/doc-page#readme",
  "bugs": {
    "url": "https://github.com/airo-studio/airo-js/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo",
    "prepublishOnly": "rm -f dist/.tsbuildinfo dist/*.tsbuildinfo"
  },
  "dependencies": {
    "@airo-js/cartridge-kit": "workspace:*",
    "@airo-js/core": "workspace:*"
  }
}
