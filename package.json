{
  "name": "airo-js",
  "private": true,
  "version": "0.0.0",
  "description": "Airo — rendering-only framework for config-driven, plugin-loaded UI.",
  "author": "AI/RO contributors",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/airo-studio/airo-js.git"
  },
  "homepage": "https://github.com/airo-studio/airo-js#readme",
  "bugs": {
    "url": "https://github.com/airo-studio/airo-js/issues"
  },
  "packageManager": "pnpm@9.4.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "pnpm -r --filter './packages/*' run build",
    "test": "pnpm -r --filter './packages/*' run test",
    "typecheck": "pnpm -r run typecheck",
    "clean": "pnpm -r run clean && rm -rf node_modules",
    "yalc:publish": "pnpm build && node scripts/yalc-publish.mjs publish",
    "yalc:push": "pnpm build && node scripts/yalc-publish.mjs push"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  }
}
