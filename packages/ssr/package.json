{
  "name": "@airo-js/ssr",
  "version": "0.8.6",
  "description": "Airo SSR — runtime-agnostic edge dispatch, renderAppToHTML, and publication-adapter execution.",
  "keywords": [
    "airo",
    "ssr",
    "edge",
    "rendering",
    "schema-org",
    "json-ld",
    "publication-adapter",
    "framework"
  ],
  "author": "AI/RO contributors",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/airo-studio/airo-js.git",
    "directory": "packages/ssr"
  },
  "homepage": "https://github.com/airo-studio/airo-js/tree/main/packages/ssr#readme",
  "bugs": {
    "url": "https://github.com/airo-studio/airo-js/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist *.tsbuildinfo",
    "prepublishOnly": "rm -f dist/.tsbuildinfo dist/*.tsbuildinfo"
  },
  "peerDependencies": {
    "@airo-js/core": "workspace:^",
    "@airo-js/cartridge-kit": "workspace:^",
    "@airo-js/log": "workspace:^"
  },
  "devDependencies": {
    "happy-dom": "^15.0.0",
    "vitest": "^2.1.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
