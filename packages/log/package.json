{
  "name": "@airo-js/log",
  "version": "0.1.0",
  "description": "Airo log — sink-based structured event logging for the airo-js framework. Replaces scattered console.* calls across @airo-js/* packages with a single dispatcher; apps replace the sink to feed events into devtools panels, Sentry, Datadog, or stay with the default console behaviour.",
  "keywords": [
    "airo",
    "framework",
    "log",
    "logger",
    "events",
    "observability",
    "devtools-sink"
  ],
  "author": "AI/RO contributors",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/airo-studio/airo-js.git",
    "directory": "packages/log"
  },
  "homepage": "https://github.com/airo-studio/airo-js/tree/main/packages/log#readme",
  "bugs": {
    "url": "https://github.com/airo-studio/airo-js/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo",
    "prepublishOnly": "rm -f dist/.tsbuildinfo dist/*.tsbuildinfo"
  },
  "publishConfig": {
    "access": "public"
  }
}
