{
  "name": "@airo-js/cartridge-kit",
  "version": "0.4.2",
  "description": "Airo cartridge contract — Cartridge<TData, TConfig> + DataSource / View / MCP tool / Template / PublicationAdapter / Gate primitives. The API surface every cartridge implements.",
  "keywords": [
    "airo",
    "cartridge",
    "plugin",
    "framework",
    "rendering",
    "ssr",
    "mcp",
    "schema-org",
    "publication-adapter"
  ],
  "author": "AI/RO contributors",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/airo-studio/airo-js.git",
    "directory": "packages/cartridge-kit"
  },
  "homepage": "https://github.com/airo-studio/airo-js/tree/main/packages/cartridge-kit#readme",
  "bugs": {
    "url": "https://github.com/airo-studio/airo-js/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist *.tsbuildinfo",
    "prepublishOnly": "rm -f dist/.tsbuildinfo dist/*.tsbuildinfo"
  },
  "peerDependencies": {
    "@airo-js/core": "workspace:^"
  },
  "devDependencies": {
    "vitest": "^2.1.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
