{
  "name": "@airo/runtime",
  "version": "0.0.0",
  "private": true,
  "description": "Airo runtime — layout chunk loader and hydration glue. Built on @airo/core.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@airo/core": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}
