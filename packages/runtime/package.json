{
  "name": "@airo-js/runtime",
  "version": "0.2.1",
  "description": "Airo runtime — cartridge mount orchestration. Single-call shell setup, data fetch, pipeline, and mount via createCartridgeApp; hooks for studio-side theme + error UI.",
  "keywords": [
    "airo",
    "framework",
    "runtime",
    "cartridge",
    "mount",
    "hydration"
  ],
  "author": "AI/RO contributors",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/airo-studio/airo-js.git",
    "directory": "packages/runtime"
  },
  "homepage": "https://github.com/airo-studio/airo-js/tree/main/packages/runtime#readme",
  "bugs": {
    "url": "https://github.com/airo-studio/airo-js/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist *.tsbuildinfo",
    "prepublishOnly": "rm -f dist/.tsbuildinfo dist/*.tsbuildinfo"
  },
  "dependencies": {
    "@airo-js/core": "workspace:^",
    "@airo-js/cartridge-kit": "workspace:^"
  },
  "devDependencies": {
    "happy-dom": "^15.0.0",
    "vitest": "^2.1.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
