{
  "name": "@ai-ro/embed",
  "version": "0.0.0",
  "private": true,
  "description": "Airo embed — ~5KB browser bootstrap loader. The script customers paste into their HTML.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "publishConfig": {
    "access": "public"
  }
}
