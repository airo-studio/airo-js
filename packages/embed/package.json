{
  "name": "@airo-js/embed",
  "version": "0.8.0",
  "description": "Airo embed — customer-facing browser bootstrap loader. Registers a custom element, fetches widget config + cartridge via host-app hooks, lazy-loads @airo-js/runtime, and mounts. ~5 KB minified bundle.",
  "keywords": [
    "airo",
    "framework",
    "embed",
    "bootstrap",
    "browser",
    "custom-element",
    "web-component"
  ],
  "author": "AI/RO contributors",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/airo-studio/airo-js.git",
    "directory": "packages/embed"
  },
  "homepage": "https://github.com/airo-studio/airo-js/tree/main/packages/embed#readme",
  "bugs": {
    "url": "https://github.com/airo-studio/airo-js/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "size": "esbuild --bundle --minify --format=iife --external:@airo-js/runtime src/index.ts | wc -c",
    "size:gzip": "esbuild --bundle --minify --format=iife --external:@airo-js/runtime src/index.ts | gzip -c | wc -c",
    "size:check": "node ./scripts/size-check.mjs",
    "clean": "rm -rf dist *.tsbuildinfo",
    "prepublishOnly": "rm -f dist/.tsbuildinfo dist/*.tsbuildinfo"
  },
  "peerDependencies": {
    "@airo-js/core": "workspace:^",
    "@airo-js/cartridge-kit": "workspace:^",
    "@airo-js/log": "workspace:^",
    "@airo-js/runtime": "workspace:^"
  },
  "devDependencies": {
    "@airo-js/cartridge-kit": "workspace:*",
    "@airo-js/core": "workspace:*",
    "@airo-js/runtime": "workspace:*",
    "esbuild": "^0.21.0",
    "happy-dom": "^15.0.0",
    "vitest": "^2.1.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
